OPENAI_API_KEY=your-openai-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-xxx
LANGFUSE_SECRET_KEY=sk-lf-xxx
LANGFUSE_HOST=https://cloud.langfuse.com

# Modelos (opcional - defaults a gpt-4o-mini)
# ORCHESTRATOR_MODEL=gpt-4o-mini
# AGENT_MODEL=gpt-4o-mini
# EVALUATOR_MODEL=gpt-4o-mini

# RAG (opcional)
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100
# RETRIEVER_K=4

# Persistencia FAISS (opcional - default: "faiss_index")
# Directorio donde se guardan los índices vectoriales entre sesiones.
# Dejar vacío para deshabilitar persistencia (reconstruye en cada startup).
# FAISS_INDEX_DIR=faiss_index

# Umbral de confianza del orquestador (opcional - default: 0.4)
# Clasificaciones por debajo generan una advertencia en los logs.
# CONFIDENCE_THRESHOLD=0.4